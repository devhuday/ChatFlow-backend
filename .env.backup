
# Configuración del servidor
PORT=3000

# Conexión a la base de datos PostgreSQL local en Docker
DATABASE_URL="postgresql://bot_wp:bot_wp_password@localhost:5432/bot_wp_db?schema=public"

# Secreto para firmar los JWT (cámbialo por uno seguro en producción)
JWT_SECRET="super_secret_jwt_key_change_me"
